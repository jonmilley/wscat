#!/usr/bin/env node

/*!
 * ws: a node.js websocket client
 * Copyright(c) 2011 Einar Otto Stangvik <einaros@gmail.com>
 * MIT Licensed
 */

import { program } from 'commander';
import { createRequire } from 'module';
import { WsEngine } from '../lib/ws-engine.js';

const require = createRequire(import.meta.url);
const version = require('../package.json').version;

const collect = (val, list) => [...list, val];

program
  .version(version)
  .usage('[options] (--listen <port> | --connect <url>)')
  .option('-l, --listen <port>', 'listen on port')
  .option('-c, --connect <url>', 'connect to a websocket server')
  .option('-m, --message <message>', 'initial message to send (repeatable)', collect, [])
  .option('-x, --execute <cmd>', 'send message on open, then close after --wait (repeatable)', collect, [])
  .option('-w, --wait <seconds>', 'wait time after --execute (-1 = hold open)', parseFloat, 2)
  .option('-p, --protocol <version>', 'optional protocol version')
  .option('-o, --origin <origin>', 'optional origin')
  .option('--host <host>', 'optional host')
  .option('-s, --subprotocol <protocol>', 'optional subprotocol (repeatable)', collect, [])
  .option('-n, --no-check', 'do not check for unauthorized certificates')
  .option('-H, --header <header:value>', 'set an HTTP header, repeat for multiple (--connect only)', collect, [])
  .option('--auth <username:password>', 'add basic HTTP authentication header (--connect only)')
  .option('--proxy <url>', 'connect via HTTP proxy')
  .option('--ca <file>', 'CA certificate file')
  .option('--cert <file>', 'client SSL certificate file')
  .option('--key <file>', 'client SSL key file')
  .option('--passphrase [value]', 'SSL key passphrase (prompts if no value given)')
  .option('-L, --location', 'follow redirects')
  .option('--max-redirects [num]', 'maximum number of redirects', 10)
  .option('--no-color', 'disable ANSI colors')
  .option('--slash', 'enable /ping, /pong, /close slash commands')
  .option('--show-ping-pong', 'print notification for received ping/pong')
  .option('-r, --retry', 'retry on disconnection (--connect only)')
  .option('-k, --keepalive <interval>', 'send a ping every interval milliseconds')
  .option('-P, --parsecommands', 'parse input for commands (send, ping, pong, close, last, counts)')
  .option('--no-tui', 'disable TUI mode, use classic readline interface')
  .parse(process.argv);

const opts = program.opts();

if (opts.listen && opts.connect) {
  process.stderr.write('\x1b[33merror: use either --listen or --connect\x1b[39m\n');
  process.exit(1);
}

if (!opts.listen && !opts.connect) {
  program.help();
}

// Validate listen port
if (opts.listen) {
  const port = parseInt(opts.listen, 10);
  if (isNaN(port) || port < 1 || port > 65535) {
    process.stderr.write('\x1b[33merror: --listen port must be a number between 1 and 65535\x1b[39m\n');
    process.exit(1);
  }
  opts.listenPort = port;
}

// Validate and normalize connect URL
if (opts.connect) {
  let connectUrl = opts.connect;
  if (!connectUrl.match(/\w+:\/\/.*$/i)) {
    connectUrl = `ws://${connectUrl}`;
  }
  try {
    new URL(connectUrl);
  } catch (e) {
    process.stderr.write(`\x1b[33merror: invalid URL "${connectUrl}"\x1b[39m\n`);
    process.exit(1);
  }
  opts.connectUrl = connectUrl;
}

// Determine whether to use TUI or readline
const useReadline = !opts.tui || !process.stdout.isTTY || (opts.execute && opts.execute.length > 0);

// Handle passphrase prompt before starting UI
async function getPassphrase() {
  if (opts.passphrase === true) {
    const { default: read } = await import('read');
    return new Promise((resolve, reject) => {
      read({ prompt: 'Passphrase: ', silent: true }, (err, passphrase) => {
        if (err) {
          process.stderr.write(`error: ${err.message}\n`);
          process.exit(1);
        }
        resolve(passphrase);
      });
    });
  }
  return opts.passphrase || undefined;
}

async function main() {
  const passphrase = opts.connect ? await getPassphrase() : undefined;
  const engine = new WsEngine(opts);

  if (useReadline) {
    const { ReadlineUI } = await import('../lib/readline-ui.js');
    const ui = new ReadlineUI(engine, opts);

    if (opts.listen) {
      ui.startListen(opts.listenPort);
    } else {
      ui.startConnect(passphrase);
    }
  } else {
    const { startTui } = await import('../lib/tui/app.js');
    startTui(engine, opts, passphrase);
  }
}

main();
