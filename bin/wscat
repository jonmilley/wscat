#!/usr/bin/env node

'use strict';

/*!
 * ws: a node.js websocket client
 * Copyright(c) 2011 Einar Otto Stangvik <einaros@gmail.com>
 * MIT Licensed
 */

const { program } = require('commander');
const readline = require('readline');
const { EventEmitter } = require('events');
const WebSocket = require('ws');
const fs = require('fs');
const { HttpsProxyAgent } = require('https-proxy-agent');
const read = require('read');

/*****************************
 * Stats tracking
 */
let interval = null;
let messagesSent = 0;
let messagesReceived = 0;
let pingsSent = 0;
let pingsReceived = 0;
let pongsSent = 0;
let pongsReceived = 0;
let lastMessage = null;
let connectionStartTime;

function printCounts() {
  const elapsed = Date.now() - connectionStartTime;
  wsConsole.print(Console.Types.Control, `Connection Open for ${elapsed} ms`, Console.Colors.Green);
  wsConsole.print(Console.Types.Control, `${messagesReceived} message(s) Received`, Console.Colors.Green);
  wsConsole.print(Console.Types.Control, `${messagesSent} message(s) Sent`, Console.Colors.Green);
  wsConsole.print(Console.Types.Control, `${pingsReceived} ping(s) Received`, Console.Colors.Green);
  wsConsole.print(Console.Types.Control, `${pingsSent} ping(s) Sent`, Console.Colors.Green);
  wsConsole.print(Console.Types.Control, `${pongsReceived} pong(s) Received`, Console.Colors.Green);
  wsConsole.print(Console.Types.Control, `${pongsSent} pong(s) Sent`, Console.Colors.Green);
  if (lastMessage) {
    wsConsole.print(Console.Types.Control, 'Last Message Received =', Console.Colors.Green);
    wsConsole.print(Console.Types.Incoming, lastMessage);
  }
}

function printCommands() {
  wsConsole.print(Console.Types.Control, "'> send <message>' to send <message> to server", Console.Colors.Green);
  wsConsole.print(Console.Types.Control, "'> ping' to send a ping to the server", Console.Colors.Green);
  wsConsole.print(Console.Types.Control, "'> pong' to send pong to the server", Console.Colors.Green);
  wsConsole.print(Console.Types.Control, "'> close' to gracefully close connection to the server", Console.Colors.Green);
  wsConsole.print(Console.Types.Control, "'> last' to reprint last received message", Console.Colors.Green);
  wsConsole.print(Console.Types.Control, "'> counts' to print frame counts", Console.Colors.Green);
}

function startKeepalive(socket) {
  return setInterval(() => {
    socket.ping();
    pingsSent++;
    wsConsole.print(Console.Types.Control, 'ping sent', Console.Colors.Green);
  }, opts.keepalive);
}

function handleSlashCommand(data) {
  if (data.startsWith('/ping')) {
    const payload = data.slice('/ping'.length).trim();
    ws.ping(payload || undefined);
    pingsSent++;
    wsConsole.print(Console.Types.Control, 'ping sent', Console.Colors.Green);
  } else if (data.startsWith('/pong')) {
    const payload = data.slice('/pong'.length).trim();
    ws.pong(payload || undefined);
    pongsSent++;
    wsConsole.print(Console.Types.Control, 'pong sent', Console.Colors.Green);
  } else if (data.startsWith('/close')) {
    const parts = data.slice('/close'.length).trim().split(/\s+/);
    const code = parts[0] ? parseInt(parts[0], 10) : 1000;
    const reason = parts.slice(1).join(' ') || '';
    ws.close(code, reason);
  } else {
    wsConsole.print(Console.Types.Error, `Unknown slash command: ${data}`, Console.Colors.Red);
  }
}

function parseInput(data) {
  if (opts.parsecommands) {
    if (data.startsWith('send ')) {
      const msg = data.slice('send '.length);
      ws.send(msg);
      wsConsole.print(Console.Types.Control, `sent (${msg})`, Console.Colors.Green);
      messagesSent++;
    } else if (data === 'ping' || data.startsWith('ping ')) {
      ws.ping();
      pingsSent++;
      wsConsole.print(Console.Types.Control, 'ping sent', Console.Colors.Green);
    } else if (data === 'pong' || data.startsWith('pong ')) {
      ws.pong();
      pongsSent++;
      wsConsole.print(Console.Types.Control, 'pong sent', Console.Colors.Green);
    } else if (data === 'close' || data.startsWith('close ')) {
      ws.close(1001, 'Client Closing.');
      wsConsole.print(Console.Types.Control, 'Connection Closed', Console.Colors.Green);
      printCounts();
      process.exit();
    } else if (data === 'last') {
      if (lastMessage) {
        wsConsole.print(Console.Types.Control, 'Last Message Received =', Console.Colors.Green);
        wsConsole.print(Console.Types.Incoming, lastMessage);
      }
    } else if (data === 'counts') {
      printCounts();
    } else if (opts.slash && data.startsWith('/')) {
      handleSlashCommand(data);
    }
  } else if (opts.slash && data.startsWith('/')) {
    handleSlashCommand(data);
  } else {
    ws.send(data);
    messagesSent++;
  }
  wsConsole.prompt();
}

/**
 * Console - wraps readline with ANSI color support.
 */
class Console extends EventEmitter {
  static Colors = Object.freeze({
    Red: '\x1b[31m',
    Green: '\x1b[32m',
    Yellow: '\x1b[33m',
    Blue: '\x1b[34m',
    Default: '\x1b[39m'
  });

  static Types = Object.freeze({
    Incoming: '< ',
    Control: '',
    Error: 'error: '
  });

  constructor() {
    super();

    this.stdin = process.stdin;
    this.stdout = process.stdout;

    this.readlineInterface = readline.createInterface(this.stdin, this.stdout);

    this.readlineInterface
      .on('line', (data) => this.emit('line', data))
      .on('close', () => this.emit('close'));

    this._resetInput = () => this.clear();
  }

  prompt(preserveCursor) {
    if (process.stdout.isTTY) {
      this.readlineInterface.prompt(preserveCursor);
    }
  }

  setPrompt(p) {
    this.readlineInterface.setPrompt(p);
  }

  print(type, msg, color) {
    if (!process.stdout.isTTY) {
      if (type === Console.Types.Incoming) {
        process.stdout.write(`${msg}\n`);
      } else if (type === Console.Types.Error) {
        process.stderr.write(`${type}${msg}\n`);
      }
      return;
    }

    this.clear();
    color = color || Console.Colors.Default;
    const prefix = type || '';
    if (opts.color !== false) {
      this.stdout.write(`${color}${prefix}${msg}${Console.Colors.Default}\n`);
    } else {
      this.stdout.write(`${prefix}${msg}\n`);
    }
    this.prompt();
  }

  clear() {
    if (process.stdout.isTTY) {
      this.stdout.write('\x1b[2K\x1b[E');
    }
  }

  pause() {
    this.stdin.on('keypress', this._resetInput);
  }

  resume() {
    this.stdin.removeListener('keypress', this._resetInput);
  }
}

// collector for repeatable options: .option(..., collect, [])
const collect = (val, list) => [...list, val];

function splitOnce(str, sep) {
  const i = str.indexOf(sep);
  return i === -1 ? [str, ''] : [str.slice(0, i), str.slice(i + 1)];
}

/**
 * The actual application
 */
const version = require('../package.json').version;

program
  .version(version)
  .usage('[options] (--listen <port> | --connect <url>)')
  .option('-l, --listen <port>', 'listen on port')
  .option('-c, --connect <url>', 'connect to a websocket server')
  .option('-m, --message <message>', 'initial message to send (repeatable)', collect, [])
  .option('-x, --execute <cmd>', 'send message on open, then close after --wait (repeatable)', collect, [])
  .option('-w, --wait <seconds>', 'wait time after --execute (-1 = hold open)', 2)
  .option('-p, --protocol <version>', 'optional protocol version')
  .option('-o, --origin <origin>', 'optional origin')
  .option('--host <host>', 'optional host')
  .option('-s, --subprotocol <protocol>', 'optional subprotocol (repeatable)', collect, [])
  .option('-n, --no-check', 'do not check for unauthorized certificates')
  .option('-H, --header <header:value>', 'set an HTTP header, repeat for multiple (--connect only)', collect, [])
  .option('--auth <username:password>', 'add basic HTTP authentication header (--connect only)')
  .option('--proxy <url>', 'connect via HTTP proxy')
  .option('--ca <file>', 'CA certificate file')
  .option('--cert <file>', 'client SSL certificate file')
  .option('--key <file>', 'client SSL key file')
  .option('--passphrase [value]', 'SSL key passphrase (prompts if no value given)')
  .option('-L, --location', 'follow redirects')
  .option('--max-redirects [num]', 'maximum number of redirects', 10)
  .option('--no-color', 'disable ANSI colors')
  .option('--slash', 'enable /ping, /pong, /close slash commands')
  .option('--show-ping-pong', 'print notification for received ping/pong')
  .option('-r, --retry', 'retry on disconnection (--connect only)')
  .option('-k, --keepalive <interval>', 'send a ping every interval milliseconds')
  .option('-P, --parsecommands', 'parse input for commands (send, ping, pong, close, last, counts)')
  .parse(process.argv);

const opts = program.opts();

let ws;
let wsConsole;

if (opts.listen && opts.connect) {
  process.stderr.write('\x1b[33merror: use either --listen or --connect\x1b[39m\n');
  process.exit(1);
} else if (opts.listen) {
  wsConsole = new Console();
  wsConsole.pause();

  const options = {};
  if (opts.protocol) options.protocolVersion = opts.protocol;
  if (opts.origin) options.origin = opts.origin;
  if (opts.subprotocol && opts.subprotocol.length) options.protocol = opts.subprotocol.join(', ');
  if (!opts.check) options.rejectUnauthorized = false;

  const wss = new WebSocket.Server({ port: opts.listen }, () => {
    wsConsole.print(Console.Types.Control, `listening on port ${opts.listen} (press CTRL+C to quit)`, Console.Colors.Green);
    if (opts.parsecommands) printCommands();
    wsConsole.clear();
  });

  wsConsole.on('close', () => {
    try { ws.close(); } catch (e) {}
    process.exit(0);
  });

  wsConsole.on('line', parseInput);

  wss.on('connection', (newClient) => {
    if (ws) return newClient.terminate();

    ws = newClient;
    wsConsole.resume();
    wsConsole.prompt();
    wsConsole.print(Console.Types.Control, 'client connected', Console.Colors.Green);
    connectionStartTime = Date.now();

    if (opts.keepalive) interval = startKeepalive(ws);

    ws.on('close', (code, reason) => {
      const reasonStr = reason ? reason.toString() : '';
      wsConsole.print(Console.Types.Control, `disconnected (code: ${code}, reason: "${reasonStr}")`, Console.Colors.Green);
      printCounts();
      if (interval != null) {
        clearInterval(interval);
        interval = null;
      }
      wsConsole.clear();
      wsConsole.pause();
      ws = null;
    }).on('error', (err) => {
      printCounts();
      wsConsole.print(Console.Types.Error, err.message, Console.Colors.Yellow);
    }).on('message', (data) => {
      lastMessage = data.toString();
      wsConsole.print(Console.Types.Incoming, lastMessage, Console.Colors.Blue);
      messagesReceived++;
    }).on('pong', () => {
      pongsReceived++;
      if (opts.showPingPong) wsConsole.print(Console.Types.Control, 'pong received', Console.Colors.Green);
    }).on('ping', () => {
      // ws v8 automatically sends the pong frame before emitting this event
      pingsReceived++;
      pongsSent++;
      if (opts.showPingPong) wsConsole.print(Console.Types.Control, 'pong sent (auto-reply)', Console.Colors.Green);
    });
  }).on('error', (err) => {
    wsConsole.print(Console.Types.Error, err.toString(), Console.Colors.Yellow);
    process.exit(1);
  });
} else if (opts.connect) {
  let isOpen = false;
  wsConsole = new Console();

  const buildOptions = (passphrase) => {
    const options = {};
    if (opts.protocol) options.protocolVersion = opts.protocol;
    if (opts.origin) options.origin = opts.origin;
    if (opts.subprotocol && opts.subprotocol.length) options.protocol = opts.subprotocol;
    if (opts.host) options.host = opts.host;
    if (!opts.check) options.rejectUnauthorized = false;
    if (opts.ca) options.ca = fs.readFileSync(opts.ca);
    if (opts.cert) options.cert = fs.readFileSync(opts.cert);
    if (opts.key) options.key = fs.readFileSync(opts.key);
    if (passphrase) options.passphrase = passphrase;
    if (opts.location) options.followRedirects = true;
    if (opts.maxRedirects) options.maxRedirects = opts.maxRedirects;
    if (opts.proxy) options.agent = new HttpsProxyAgent(opts.proxy);

    const headers = {};
    (opts.header || []).forEach((h) => {
      const [key, val] = splitOnce(h, ':');
      headers[key] = val;
    });

    if (opts.auth) {
      headers['Authorization'] = `Basic ${Buffer.from(opts.auth).toString('base64')}`;
    }

    options.headers = headers;
    return options;
  };

  let connectUrl = opts.connect;
  if (!connectUrl.match(/\w+:\/\/.*$/i)) {
    connectUrl = `ws://${connectUrl}`;
  }

  let retryTimer = null;
  let numRetries = 0;
  const maxRetries = 4;

  const retry = () => {
    if (retryTimer) return;
    if (++numRetries > maxRetries) {
      wsConsole.setPrompt('disconnected, press return to retry or ctrl-c to quit');
      wsConsole.prompt();
    } else {
      retryTimer = setTimeout(() => {
        retryTimer = null;
        connect(cachedPassphrase);
      }, 500);
    }
  };

  let cachedPassphrase;

  const connect = (passphrase) => {
    if (ws) return;

    if (opts.retry) {
      wsConsole.setPrompt('connecting... ');
      wsConsole.prompt();
    }

    ws = new WebSocket(connectUrl, buildOptions(passphrase));

    ws.on('open', () => {
      connectionStartTime = Date.now();

      if (opts.keepalive) interval = startKeepalive(ws);

      wsConsole.print(Console.Types.Control, 'connected (press CTRL+C to quit)', Console.Colors.Green);

      // --message: send then stay interactive
      (opts.message || []).forEach((msg) => {
        ws.send(msg);
        wsConsole.print(Console.Types.Control, `> ${msg}`);
        messagesSent++;
      });

      // --execute: send then close after --wait seconds
      if (opts.execute.length > 0) {
        opts.execute.forEach((msg) => {
          ws.send(msg);
          wsConsole.print(Console.Types.Control, `> ${msg}`);
          messagesSent++;
        });
        const waitSecs = parseFloat(opts.wait);
        if (waitSecs >= 0) setTimeout(() => ws.close(), waitSecs * 1000);
        // waitSecs === -1: hold open forever (user must Ctrl+C)
      }

      wsConsole.setPrompt('> ');
      wsConsole.prompt();
      isOpen = true;
      numRetries = 0;
    }).on('close', (code, reason) => {
      isOpen = false;
      const reasonStr = reason ? reason.toString() : '';
      wsConsole.print(Console.Types.Control, `disconnected (code: ${code}, reason: "${reasonStr}")`, Console.Colors.Green);
      if (interval != null) {
        clearInterval(interval);
        interval = null;
      }
      wsConsole.clear();
      ws = null;
      if (opts.retry) {
        retry();
      } else {
        process.exit();
      }
    }).on('error', (err) => {
      if (numRetries === 0) {
        printCounts();
        wsConsole.print(Console.Types.Error, err.message, Console.Colors.Yellow);
      }
      ws = null;
      if (opts.retry) {
        retry();
      } else {
        printCounts();
        process.exit(1);
      }
    }).on('message', (data) => {
      messagesReceived++;
      lastMessage = data.toString();
      wsConsole.print(Console.Types.Incoming, lastMessage, Console.Colors.Blue);
    }).on('pong', () => {
      pongsReceived++;
      if (opts.showPingPong) wsConsole.print(Console.Types.Control, 'pong received', Console.Colors.Green);
    }).on('ping', () => {
      // ws v8 automatically sends the pong frame before emitting this event
      pingsReceived++;
      pongsSent++;
      if (opts.showPingPong) wsConsole.print(Console.Types.Control, 'pong sent (auto-reply)', Console.Colors.Green);
    });
  };

  // Handle --passphrase: prompt interactively if no value given
  if (opts.passphrase === true) {
    read({ prompt: 'Passphrase: ', silent: true }, (err, passphrase) => {
      if (err) {
        process.stderr.write(`error: ${err.message}\n`);
        process.exit(1);
      }
      cachedPassphrase = passphrase;
      connect(passphrase);
    });
  } else {
    cachedPassphrase = opts.passphrase;
    connect(opts.passphrase);
  }

  wsConsole.on('line', (data) => {
    if (!isOpen && numRetries > maxRetries) { numRetries = 0; connect(cachedPassphrase); }
    if (!isOpen) return;
    parseInput(data);
  });

  wsConsole.on('close', () => {
    printCounts();
    if (!ws) return;
    try { ws.close(); } catch (e) {}
    process.exit();
  });
} else {
  program.help();
}
